{
  "expo": {
    "name": "Aura Campus",
    "slug": "aura-campus-pro",
    "owner": "aura-campus-pro",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "aura",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#7C3AED"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "edu.aura.mobile"
    },
    "android": {
      "package": "edu.aura.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#7C3AED"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-asset",
      "expo-font",
      "expo-dev-client"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "052839cc-5a5b-47f7-aefc-b2f632447c34"
      }
    }
  }
}
