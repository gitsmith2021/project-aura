# ─────────────────────────────────────────────────────────────────────────────
# Aura Campus mobile — environment (local dev / Expo Go / `expo start`).
# Copy to `.env` and fill in. These EXPO_PUBLIC_* vars are inlined into the JS
# bundle at build time, so they must NOT hold secrets — only public values.
#
# For EAS cloud builds the Supabase values are already set per-profile in
# eas.json; EXPO_PUBLIC_API_BASE_URL is the one deployment-specific var you set
# per environment (see below).
# ─────────────────────────────────────────────────────────────────────────────

# Same Supabase project as the web app — same Postgres, auth, and RLS.
# The publishable ("anon") key is safe in the client bundle; RLS protects data.
EXPO_PUBLIC_SUPABASE_URL=https://nsaheksysxinemtjcako.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_0QZApyONjzPE8uplpbaOlA_9gdWwQZ0

# Base URL of the Aura web app — used by the authenticated mobile APIs
# (/api/parent, /api/staff, /api/executive). Point it at:
#   • local dev   → your machine's LAN IP running `npm run dev`, e.g. http://192.168.1.20:3000
#   • staging/prod → the deployed web URL
# The core app (auth + RLS screens) works without it; parent / staff-marks /
# executive screens need it. For EAS builds, set it per-environment with:
#   eas env:create --environment development --name EXPO_PUBLIC_API_BASE_URL --value <url>
EXPO_PUBLIC_API_BASE_URL=
